  },
  "peerDependencies": {
    "modelence": "*"
  },
  "devDependencies": {
    "modelence": "^0.12.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
